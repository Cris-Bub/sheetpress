# sheetPress SaaS fork — environment variables.
# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase project URL. Local default is http://127.0.0.1:54321 (printed by
# `supabase start`). For a hosted project, use the URL from the dashboard.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase publishable / anon key. Local default is printed by `supabase start`;
# hosted projects show it under Settings → API.
# Publishable keys (sb_publishable_...) and legacy anon keys both work here —
# either is safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...replace-me

# Service-role key — server-side ONLY. Never prefix this with NEXT_PUBLIC_,
# never log it, never put it in client code. Used for admin operations that
# bypass RLS. We don't use it in Phases 1–3 but reserve the slot.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...replace-me
